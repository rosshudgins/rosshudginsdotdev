---
import site from "@/config/site";
import type { HeadProps } from "@/types";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

type Props = HeadProps;

const { title, description, image = site.ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteIcon = site.meta.logo;
---

<!-- Global Metadata -->
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <script type="application/ld+json"> 
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Ross Hudgins",
      "url": "https://rosshudgins.dev",
      "jobTitle": "Web Developer",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Longmont",
        "addressRegion": "CO",
        "addressCountry": "US"
      },
      "sameAs": [
        "https://github.com/rosshudgins",
        "https://www.linkedin.com/in/michaelrosshudgins/"
      ]
    }
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/jpeg" href={siteIcon} />
  <link rel="icon" type="image/jpeg" sizes="16x16" href={siteIcon} />
  <link rel="icon" type="image/jpeg" sizes="32x32" href={siteIcon} />

  <!-- Apple Touch Icon -->
  <link rel="apple-touch-icon" sizes="180x180" href={siteIcon} />

  <!-- PWA Icons -->
  <link rel="icon" type="image/jpeg" sizes="192x192" href={siteIcon} />
  <link rel="icon" type="image/jpeg" sizes="512x512" href={siteIcon} />

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json" />

  <!-- Theme Color -->
  <meta name="theme-color" content="#3F9C87" />
  <meta name="msapplication-TileColor" content="#3F9C87" />

  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta name="twitter:creator" content={`@${site.meta.author}`} />
  <meta name="twitter:image" content={new URL(image, Astro.url)} />

  <!-- RSS Link -->
  <link
    rel="alternate"
    type="application/rss+xml"
    title={site.meta.title}
    href={new URL("rss.xml", Astro.site)}
  />

  <!-- canonical url -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- pagefind -->
  {import.meta.env.PROD ? (
    <>
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
      <script src="/pagefind/pagefind-ui.js" is:inline></script>
    </>
  ) : null}

  <!-- font  -->
  <Font cssVariable="--font-display" preload />

  <!-- View Transtions -->
  <ClientRouter />
</head>
